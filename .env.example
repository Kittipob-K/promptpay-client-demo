# NotiBank API base URL
API_BASE=http://localhost:3001

# Demo client port
PORT=3002

# API key from NotiBank dashboard.
# Create it in API Keys and keep the sk_line_... value here only.
API_KEY=sk_line_your_key_here

# Optional: set this only when the selected API key has a webhook secret
# and you want this demo receiver to verify NotiBank webhook signatures.
WEBHOOK_SECRET=your_api_key_webhook_secret_here
