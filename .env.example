# NestJS server base URL
API_BASE=http://localhost:3000

# Port for this demo client
PORT=3001

# Your API key (starts with sk_line_) — create via dashboard → API Keys
# Set this key's webhook URL to: http://localhost:3001/webhook
API_KEY=sk_line_your_key_here

# Must match WEBHOOK_SECRET in the NestJS .env
WEBHOOK_SECRET=your_webhook_secret_here

# PromptPay ID to display in the UI (phone / national_id / tax_id / ewallet)
PROMPTPAY_ID=0812345678
PROMPTPAY_TYPE=phone
